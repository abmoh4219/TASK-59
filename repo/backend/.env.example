# Stub env file for Docker build-time tooling (composer post-install / cache:clear).
# Not used at runtime: docker-compose injects real values via the `environment:` block,
# and local dev copies the repo-root .env.example → backend/.env via the `setup` service.
APP_ENV=test
APP_SECRET=test-secret-key-for-testing-only!
DATABASE_URL="mysql://wfops:wfops_pass@mysql-test:3306/wfops_test?serverVersion=8.0"
APP_ENCRYPTION_KEY=test-encryption-key-32-bytes-ok!
APP_SIGNING_KEY=test-signing-key-for-hmac-tests
CORS_ALLOW_ORIGIN=http://localhost:3000
